            "icon": "phosphor/regular/handshake",
            "mode": "nested"
          },
          "/ui": {
            "type": "openapi",
            "title": "UI",
            "filepath": "docs/api-reference/ui.json",
            "icon": "phosphor/regular/desktop",
            "mode": "nested"
          },
          "/data": {
            "type": "openapi",
