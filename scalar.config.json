{
  "$schema": "https://registry.scalar.com/@scalar/schemas/config",
  "scalar": "2.0.0",
  "info": {
    "title": "Future Begins — Enterprise API",
    "description": "Interactive API reference for the Future Begins Enterprise platform. 1,236 operations across 20 modules."
  },
  "siteConfig": {
    "theme": "default"
  },
  "navigation": {
    "header": [
      {
        "type": "link",
        "title": "Future Begins",
        "to": "/"
      },
      { "type": "spacer" },
      {
        "type": "link",
        "title": "GitHub",
        "icon": "phosphor/regular/github-logo",
        "to": "https://github.com/thefuturebegins/enterprise-api-docs",
        "newTab": true
      }
    ],
    "sidebar": [
      {
        "title": "GitHub",
        "url": "https://github.com/thefuturebegins/enterprise-api-docs",
        "icon": "phosphor/regular/github-logo"
      }
    ],
    "tabs": [
      {
        "title": "Guides",
        "path": "/",
        "icon": "phosphor/regular/book-open"
      },
      {
        "title": "API Reference",
        "path": "/api",
        "icon": "phosphor/regular/plug"
      }
    ],
    "routes": {
      "/": {
        "type": "group",
        "title": "Overview",
        "mode": "flat",
        "children": {
          "/": {
            "type": "page",
            "title": "Introduction",
            "filepath": "docs/guides/introduction.md",
            "icon": "phosphor/regular/house"
          },
          "/getting-started": {
            "type": "page",
            "title": "Getting Started",
            "filepath": "docs/guides/getting-started.md",
            "icon": "phosphor/regular/rocket"
          },
          "/authentication": {
            "type": "page",
            "title": "Authentication",
            "filepath": "docs/guides/authentication.md",
            "icon": "phosphor/regular/lock"
          }
        }
      },
      "/api": {
        "type": "group",
        "title": "API Reference",
        "mode": "flat",
        "children": {
          "/analytics": {
            "type": "openapi",
            "title": "Analytics",
            "filepath": "docs/api-reference/analytics.json",
            "icon": "phosphor/regular/chart-bar",
            "mode": "nested"
          },
          "/cache": {
            "type": "openapi",
            "title": "Cache",
            "filepath": "docs/api-reference/cache.json",
            "icon": "phosphor/regular/database",
            "mode": "nested"
          },
          "/finance": {
            "type": "openapi",
            "title": "Finance",
            "filepath": "docs/api-reference/finance.json",
            "icon": "phosphor/regular/currency-dollar",
            "mode": "nested"
          },
          "/integrations": {
            "type": "openapi",
            "title": "Integrations",
            "filepath": "docs/api-reference/integrations.json",
            "icon": "phosphor/regular/plugs-connected",
            "mode": "nested"
          },
          "/notifications": {
            "type": "openapi",
            "title": "Notifications",
            "filepath": "docs/api-reference/notifications.json",
            "icon": "phosphor/regular/bell",
            "mode": "nested"
          },
          "/permissions": {
            "type": "openapi",
            "title": "Permissions",
            "filepath": "docs/api-reference/permissions.json",
            "icon": "phosphor/regular/lock",
            "mode": "nested"
          },
          "/pipelines": {
            "type": "openapi",
            "title": "Pipelines",
            "filepath": "docs/api-reference/pipelines.json",
            "icon": "phosphor/regular/flow-arrow",
            "mode": "nested"
          },
