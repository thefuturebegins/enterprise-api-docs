            "filepath": "docs/api-reference/workflow.json",
            "icon": "phosphor/regular/git-branch",
            "mode": "nested"
          },
          "/customerSuccess": {
            "type": "openapi",
            "title": "Customer Success",
            "filepath": "docs/api-reference/customerSuccess.json",
            "icon": "phosphor/regular/star",
            "mode": "nested"
          },
          "/forms": {
            "type": "openapi",
            "title": "Forms",
            "filepath": "docs/api-reference/forms.json",
            "icon": "phosphor/regular/clipboard-text",
            "mode": "nested"
          },
          "/inventory": {
            "type": "openapi",
            "title": "Inventory",
            "filepath": "docs/api-reference/inventory.json",
            "icon": "phosphor/regular/package",
            "mode": "nested"
          },
          "/settings": {
            "type": "openapi",
            "title": "Settings",
            "filepath": "docs/api-reference/settings.json",
            "icon": "phosphor/regular/sliders",
            "mode": "nested"
          },
          "/support": {
            "type": "openapi",
            "title": "Support",
            "filepath": "docs/api-reference/support.json",
            "icon": "phosphor/regular/lifebuoy",
            "mode": "nested"
          }
        }
      }
    }
  }
}
