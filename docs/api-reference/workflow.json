  "components": {
    "schemas": {
      "ScheduledEvent": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "eventTypeKey": {
            "type": "string",
            "description": "IEventType.key that will be published when the timer fires."
          },
          "eventTypeName": {
            "type": "string",
            "description": "Optional display name (defaults to eventTypeKey if absent)."
          },
          "source": {
            "$ref": "#/components/schemas/IEventSource",
            "description": "Optional event source override. Defaults to scheduledEvents source."
          },
          "payload": {
            "description": "Arbitrary serialisable payload published with the event."
          },
          "workflow": {
            "$ref": "#/components/schemas/ScheduledEventWorkflow",
            "description": "Optional workflow-binding wrapper."
          },
          "triggerAt": {
            "type": "string",
            "format": "date-time",
            "description": "Single-shot trigger time. Mutually exclusive with `cron`."
          },
          "cron": {
            "type": "string",
            "description": "Cron expression (5- or 6-field syntax). Mutually exclusive with triggerAt."
          },
          "timezone": {
            "type": "string",
            "description": "IANA timezone for cron evaluation. Defaults to UTC."
          },
          "nextRunAt": {
            "type": "string",
            "format": "date-time",
            "description": "Always populated \u2014 the worker watches this column."
          },
          "lastRunAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the last fire actually happened."
          },
          "endAt": {
            "type": "string",
            "format": "date-time",
            "description": "Optional end-of-recurrence cutoff."
          },
          "maxRuns": {
            "type": "number",
            "description": "Optional maximum number of fires (cron only)."
          },
          "runCount": {
            "type": "number",
            "description": "Increments after each successful fire."
          },
          "status": {
            "$ref": "#/components/schemas/ScheduledEventStatus"
          },
          "error": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "accountId",
          "eventTypeKey",
          "payload",
          "nextRunAt",
          "runCount",
          "status",
          "createdAt"
        ]
      },
      "IEventSource": {},
      "ScheduledEventWorkflow": {
        "type": "object",
        "properties": {
          "modelKey": {
            "type": "string"
          },
          "recordId": {
            "type": "string"
          },
          "when": {
            "type": "string",
            "description": "Matches WorkflowDefinition.when \u2014 e.g. \"schedule\", \"follow-up\"."
          }
        },
        "required": [
          "modelKey",
          "recordId",
          "when"
        ]
      },
      "ScheduledEventStatus": {},
      "ScheduleEventInput": {
        "type": "object",
        "properties": {
          "eventTypeKey": {
            "type": "string"
          },
          "eventTypeName": {
            "type": "string"
          },
          "source": {
            "$ref": "#/components/schemas/IEventSource"
          },
          "payload": {}
        },
        "required": [
          "eventTypeKey"
        ]
      },
      "ScheduleWorkflowInput": {
        "type": "object",
        "properties": {
          "modelKey": {
            "type": "string"
          },
          "recordId": {
            "type": "string"
          },
          "when": {
            "type": "string",
            "description": "Workflow trigger key. Defaults to \"schedule\"."
          },
          "payload": {
            "description": "Optional additional payload passed alongside the workflow invocation."
          }
        },
        "required": [
          "modelKey",
          "recordId"
        ]
      },
      "ListScheduledEventsFilters": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/ScheduledEventStatus"
          },
          "eventTypeKey": {
            "type": "string"
          },
          "modelKey": {
            "type": "string"
          },
          "recordId": {
            "type": "string"
          },
          "nextRunFrom": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "string"
              }
            ],
