        "type": "object",
        "properties": {
          "avatarUrl": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/SafeUser"
          }
        },
        "required": [
          "avatarUrl",
          "user"
        ]
      },
      "SafeUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "_id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "avatar": {
            "type": [
              "string",
              "null"
            ]
          },
          "phone": {
            "type": "string"
          },
          "emailVerified": {
            "type": "boolean"
          },
          "authProvider": {
            "type": "string"
          },
          "lastLogin": {
            "type": "string",
            "format": "date-time"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "email"
        ]
      },
      "AvatarUploadData": {
        "type": "object",
        "properties": {
          "data": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "string",
                "format": "binary"
              }
            ]
          },
          "mimetype": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          }
        },
        "required": [
          "data",
          "mimetype",
          "filename"
        ]
      },
      "MessageResult": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      },
      "AuthResult": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/SafeUser"
          },
          "token": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "expiresIn": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "required": [
          "user",
          "token"
        ]
      },
      "BrokerOAuthExchangeRequest": {
        "type": "object",
        "properties": {
          "provider": {
            "$ref": "#/components/schemas/OAuthProvider"
          },
          "profile": {
            "$ref": "#/components/schemas/OAuthProfile"
          },
          "timestamp": {
            "type": "number",
            "description": "Unix epoch milliseconds when the broker built the payload"
          },
          "signature": {
            "type": "string",
            "description": "hex-encoded HMAC-SHA256 of `${timestamp}.${canonicalPayload}` using OAUTH_BROKER_SHARED_SECRET; canonicalPayload = provider,id,email,name,given_name,family_name,picture joined with newline (see AuthenticationService)"
          }
        },
        "required": [
          "provider",
          "profile",
          "timestamp",
          "signature"
        ]
      },
      "OAuthProvider": {
        "type": "string",
        "enum": [
          "google",
          "facebook",
          "twitter",
          "apple",
          "microsoft"
        ]
      },
      "OAuthProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "given_name": {
            "type": "string"
          },
          "family_name": {
            "type": "string"
          },
          "picture": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "given_name",
          "family_name"
        ]
      }
    }
  }
}
