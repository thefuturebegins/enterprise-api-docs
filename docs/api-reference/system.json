  "components": {
    "schemas": {
      "Job": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "jobType": {
            "type": "string"
          },
          "schedule": {
            "type": "string",
            "description": "Cron expression (e.g. \"0 1 * * *\")"
          },
          "repeatTimezone": {
            "type": "string",
            "enum": [
              "UTC",
              "America/New_York",
              "America/Chicago",
              "America/Denver",
              "America/Phoenix",
              "America/Los_Angeles",
              "America/Anchorage",
              "Pacific/Honolulu"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "paused"
            ]
          },
          "parameters": {
            "type": "object",
            "additionalProperties": true,
            "description": "Runtime parameters passed to the job handler"
          },
          "lastRunAt": {
            "type": "string",
            "format": "date-time"
          },
          "nextRunAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdByDate": {
            "type": "string",
            "format": "date-time"
          },
          "updatedByDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "name",
          "jobType",
          "status"
        ]
      },
      "JobFilter": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "jobType": {
            "type": "string"
          },
          "schedule": {
            "type": "string",
            "description": "Cron expression (e.g. \"0 1 * * *\")"
          },
          "repeatTimezone": {
            "type": "string",
            "enum": [
              "UTC",
              "America/New_York",
              "America/Chicago",
              "America/Denver",
              "America/Phoenix",
              "America/Los_Angeles",
              "America/Anchorage",
              "Pacific/Honolulu"
            ]
          },
          "status": {
            "type": "string",
