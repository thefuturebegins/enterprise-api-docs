{
  "openapi": "3.1.0",
  "info": {
    "title": "permissions API",
    "version": "1.0.6",
    "description": "Authorisation layer \u2014 check and enforce permission rules based on user roles and explicit grants.\n\n## Sections\n\n- [Authorization](#authorization)"
  },
  "tags": [
    {
      "name": "Authorization"
    }
  ],
  "paths": {
    "/api/permissions/check": {
      "get": {
        "operationId": "permissions.authorization.hasPermission",
        "tags": [
          "Authorization"
        ],
        "summary": "Check if user has a specific permission",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "permissionKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "accountId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "x-scope": "clientServer",
        "x-permission": "permissions:authorization:read",
        "description": "Check if user has a specific permission\n\nCustom logic: Resolves user \u2192 roles \u2192 permissions chain"
      }
    },
    "/api/permissions/user/{userId}": {
      "get": {
        "operationId": "permissions.authorization.getEffectivePermissionsForUser",
        "tags": [
          "Authorization"
        ],
        "summary": "Get effective permissions for a user",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "accountId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "x-scope": "clientServer",
        "x-permission": "permissions:authorization:read",
        "description": "Get effective permissions for a user\n\nCustom logic:\n- Aggregates from all user roles\n- Resolves from Enterprise DB\n- Deduplicates permissions"
      }
    },
    "/api/permissions/catalog": {
      "get": {
        "operationId": "permissions.authorization.getPermissionsCatalog",
        "tags": [
          "Authorization"
        ],
        "summary": "Get complete permissions catalog",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PermissionsCatalog"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "parameters": [
          {
            "name": "accountId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "x-scope": "clientServer",
        "x-permission": "permissions:authorization:read",
        "description": "Get complete permissions catalog\n\nCustom logic: Aggregates from Enterprise DB + Tenant DB"
      }
    }
  },
  "components": {
    "schemas": {
      "PermissionsCatalog": {
        "type": "object",
        "properties": {
          "modules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Module"
            }
          },
          "features": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Feature"
            }
          },
          "permissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Permission"
            }
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Role"
            }
          },
          "rolePermissionSelections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RolePermissionSelection"
            }
          },
          "userRoleSelections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserRoleSelection"
            }
          },
          "summary": {
            "type": "object",
            "properties": {
              "modulesCount": {
                "type": "number"
              },
              "featuresCount": {
                "type": "number"
              },
              "permissionsCount": {
                "type": "number"
              },
              "rolesCount": {
                "type": "number"
              }
            },
            "required": [
              "modulesCount",
              "featuresCount",
              "permissionsCount",
              "rolesCount"
            ]
          }
        },
        "required": [
          "modules",
          "features",
          "permissions",
          "roles",
          "rolePermissionSelections",
          "userRoleSelections"
        ]
      },
      "Module": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "key",
          "name"
        ]
      },
      "Feature": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "moduleId": {
            "type": "string"
          },
          "moduleKey": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "key",
          "name",
          "moduleId",
          "moduleKey"
        ]
      },
      "Permission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "moduleId": {
            "type": "string"
          },
          "moduleKey": {
            "type": "string"
          },
          "featureId": {
            "type": "string"
          },
          "featureKey": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "key",
          "name",
          "moduleId",
          "moduleKey",
          "featureId",
          "featureKey"
        ]
      },
      "Role": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "isSystem": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "key",
          "name"
        ]
      },
      "RolePermissionSelection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "roleId": {
            "type": "string"
          },
          "permissionId": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "roleId",
          "permissionId"
        ]
      },
      "UserRoleSelection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "roleId": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "userId",
          "roleId"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "https://api.enterprisecrm.com",
      "description": "Production API"
    }
  ]
}
